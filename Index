        // Physics Simulation Variables
        let cannonCanvas, cannonCtx, cannonFrameId;
        let sandboxCanvas, sandboxCtx, sandboxFrameId;
        let sandboxMassMode = 'normal';

        // URL hash router to toggle views and trigger dashboard tabs
        function router() {
            const hash = window.location.hash;
            const portalView = document.getElementById('portal-view');
            const widgetView = document.getElementById('widget-view');

            stopAllAnimations();

            if (!hash || hash === '#home' || hash === '#index') {
                // Show index page
                portalView.classList.remove('hidden');
                widgetView.classList.add('hidden');
            } else {
                // Show widget page
                portalView.classList.add('hidden');
                widgetView.classList.remove('hidden');

                if (hash === '#freefall') {
                    switchTab('freefall');
                } else if (hash === '#sandbox') {
                    switchTab('sandbox');
                } else if (hash === '#vocab') {
                    switchTab('vocab');
                }
            }
        }

        // Switch tabs manually on the dashboard
        function switchTab(tabId) {
            if (currentTab === tabId) return;
            
            const tabs = ['freefall', 'sandbox', 'vocab'];
            tabs.forEach(t => {
                const btn = document.getElementById(`tab-btn-${t}`);
                const panel = document.getElementById(`panel-${t}`);
                
                if (t === tabId) {
                    btn.className = "flex-1 md:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-sky-500/10 border border-sky-500/20 text-sky-400 rounded-lg text-xs font-semibold transition-all";
                    panel.classList.remove('hidden');
                    panel.classList.add('flex');
                } else {
                    btn.className = "flex-1 md:flex-none flex items-center justify-center gap-2 px-4 py-2 hover:bg-slate-900 text-slate-400 hover:text-slate-200 rounded-lg text-xs font-semibold transition-all";
                    panel.classList.add('hidden');
                    panel.classList.remove('flex');
                }
            });

            stopAllAnimations();
            currentTab = tabId;

            // Trigger specific animations on demand
            if (tabId === 'freefall') {
                setTimeout(initCannonCanvas, 50);
            } else if (tabId === 'sandbox') {
                setTimeout(initSandboxCanvas, 50);
            }
        }

        function stopAllAnimations() {
            if (cannonFrameId) cancelAnimationFrame(cannonFrameId);
            if (sandboxFrameId) cancelAnimationFrame(sandboxFrameId);
        }

        // Clipboard Copy Logic with Toast Notifier
        function copyEmbedLink(hashType) {
            const baseUrl = window.location.href.split('#')[0];
            const embedUrl = `${baseUrl}#${hashType}`;

            const tempInput = document.createElement('input');
            tempInput.value = embedUrl;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand('copy');
            document.body.removeChild(tempInput);

            // Pop toast alert
            const toast = document.getElementById('toast');
            document.getElementById('toast-msg').textContent = `Copied #${hashType} Canva link!`;
            toast.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
            
            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
            }, 2500);
        }

        // ==================== WIDGET 1: NEWTON CANNONBALL LOGIC ====================
        function initCannonCanvas() {
            cannonCanvas = document.getElementById('cannonCanvas');
            cannonCtx = cannonCanvas.getContext('2d');
            resetCannonScene();
        }

        function resetCannonScene() {
            if (cannonFrameId) cancelAnimationFrame(cannonFrameId);
            cannonCtx.clearRect(0, 0, cannonCanvas.width, cannonCanvas.height);
            
            // Draw Earth
            cannonCtx.beginPath();
            cannonCtx.arc(200, 150, 55, 0, 2 * Math.PI);
            cannonCtx.fillStyle = "#3b82f6";
            cannonCtx.fill();
            cannonCtx.lineWidth = 2;
            cannonCtx.strokeStyle = "#1d4ed8";
            cannonCtx.stroke();

            // Draw Mountain Cannon Base
            cannonCtx.beginPath();
            cannonCtx.moveTo(194, 95);
            cannonCtx.lineTo(200, 82);
            cannonCtx.lineTo(206, 95);
            cannonCtx.fillStyle = "#64748b";
            cannonCtx.fill();
        }

        function launchCannonball(speedType) {
            resetCannonScene();
            document.getElementById('cannon-status').textContent = "Tracking " + speedType + " velocity...";
            
            let x = 200;
            let y = 81;
            let vx = 0;
            let vy = 0;
            let path = [];

            if (speedType === 'low') {
                vx = 1.35;
                vy = -0.3;
            } else if (speedType === 'medium') {
                vx = 2.6;
                vy = -0.5;
            } else if (speedType === 'orbital') {
                vx = 3.9;
                vy = 0;
            }

            const earthX = 200;
            const earthY = 150;
            const earthR = 55;

            function animate() {
                const dx = x - earthX;
                const dy = y - earthY;
                const distance = Math.sqrt(dx*dx + dy*dy);

                if (distance < earthR) {
                    document.getElementById('cannon-status').textContent = "Impact Detected!";
                    return;
                }

                const gravityStrength = 0.17;
                const ax = -gravityStrength * (dx / distance);
                const ay = -gravityStrength * (dy / distance);

                vx += ax;
                vy += ay;
                x += vx;
                y += vy;

                path.push({x: x, y: y});

                cannonCtx.clearRect(0, 0, cannonCanvas.width, cannonCanvas.height);

                // Draw Earth
                cannonCtx.beginPath();
                cannonCtx.arc(earthX, earthY, earthR, 0, 2 * Math.PI);
                cannonCtx.fillStyle = "#1e40af";
                cannonCtx.fill();
                cannonCtx.strokeStyle = "#1d4ed8";
                cannonCtx.stroke();

                // Draw Track path line
                cannonCtx.beginPath();
                cannonCtx.moveTo(200, 81);
                path.forEach(p => cannonCtx.lineTo(p.x, p.y));
                cannonCtx.strokeStyle = speedType === 'orbital' ? '#10b981' : (speedType === 'medium' ? '#f59e0b' : '#f43f5e');
                cannonCtx.lineWidth = 2;
                cannonCtx.stroke();

                // Draw Cannonball
                cannonCtx.beginPath();
                cannonCtx.arc(x, y, 4, 0, 2 * Math.PI);
                cannonCtx.fillStyle = "#facc15";
                cannonCtx.fill();

                if (speedType === 'orbital' && path.length > 300) {
                    path.shift();
                }

                cannonFrameId = requestAnimationFrame(animate);
            }
            animate();
        }

        // ==================== WIDGET 2: STAR MASS SANDBOX LOGIC ====================
        function initSandboxCanvas() {
            sandboxCanvas = document.getElementById('sandboxCanvas');
            sandboxCtx = sandboxCanvas.getContext('2d');
            runSandboxOrbit();
        }

        function changeSandboxMass(mode) {
            sandboxMassMode = mode;
            const status = document.getElementById('sandbox-status');
            
            const buttons = ['half', 'normal', 'double'];
            buttons.forEach(b => {
                const el = document.getElementById(`btn-${b}`);
                if (b === mode) {
                    el.className = "py-2.5 bg-purple-500/20 border border-purple-500/30 rounded-lg text-xs font-bold text-purple-400 transition-all";
                } else {
                    el.className = "py-2.5 bg-slate-900 border border-slate-800 hover:border-purple-500/30 rounded-lg text-xs font-semibold text-slate-300 transition-all";
                }
            });

            if (mode === 'half') {
                status.textContent = "Weak Gravity: Spiral Outward";
            } else if (mode === 'normal') {
                status.textContent = "Normal Orbit Track";
            } else if (mode === 'double') {
                status.textContent = "Strong Gravity: Spiral Decay Collapse";
            }
            runSandboxOrbit();
        }

        function runSandboxOrbit() {
            if (sandboxFrameId) cancelAnimationFrame(sandboxFrameId);
            sandboxCtx.clearRect(0, 0, sandboxCanvas.width, sandboxCanvas.height);

            let angle = 0;
            let x = 200;
            let y = 140;
            let radius = 70;
            let orbitPath = [];

            function animate() {
                sandboxCtx.clearRect(0, 0, sandboxCanvas.width, sandboxCanvas.height);

                let starRadius = 14;
                let starColor = "#facc15";
                
                if (sandboxMassMode === 'half') {
                    starRadius = 8;
                    starColor = "#f97316";
                } else if (sandboxMassMode === 'double') {
                    starRadius = 22;
                    starColor = "#38bdf8";
                }

                // Draw central solar mass
                sandboxCtx.beginPath();
                sandboxCtx.arc(200, 140, starRadius, 0, 2 * Math.PI);
                sandboxCtx.fillStyle = starColor;
                sandboxCtx.fill();

                if (sandboxMassMode === 'normal') {
                    angle += 0.025;
                    x = 200 + radius * Math.cos(angle);
                    y = 140 + radius * Math.sin(angle);
                } else if (sandboxMassMode === 'half') {
                    radius += 0.6;
                    angle += 0.02;
                    x = 200 + radius * Math.cos(angle);
                    y = 140 + radius * Math.sin(angle);
                } else if (sandboxMassMode === 'double') {
                    radius -= 0.42;
                    angle += 0.038;
                    if (radius < starRadius) {
                        sandboxCtx.fillStyle = "#f43f5e";
                        sandboxCtx.font = "bold 14px monospace";
                        sandboxCtx.textAlign = "center";
                        sandboxCtx.fillText("COLLISION IMPACT!", 200, 145);
                        return;
                    }
                    x = 200 + radius * Math.cos(angle);
                    y = 140 + radius * Math.sin(angle);
                }

                orbitPath.push({x: x, y: y});
                if (orbitPath.length > 200) orbitPath.shift();

                // Draw orbiting trajectory line
                sandboxCtx.beginPath();
                sandboxCtx.moveTo(orbitPath[0].x, orbitPath[0].y);
                orbitPath.forEach(p => sandboxCtx.lineTo(p.x, p.y));
                sandboxCtx.strokeStyle = "rgba(56, 189, 248, 0.25)";
                sandboxCtx.lineWidth = 1.5;
                sandboxCtx.stroke();

                // Draw orbiting planet
                sandboxCtx.beginPath();
                sandboxCtx.arc(x, y, 6, 0, 2 * Math.PI);
                sandboxCtx.fillStyle = "#3b82f6";
                sandboxCtx.fill();

                sandboxFrameId = requestAnimationFrame(animate);
            }
            animate();
        }

        // ==================== TAB 3: TRANSLATION FLIP CARDS LOGIC ====================
        function flipCard(cardElement) {
            cardElement.classList.toggle('flipped');
        }

        // Listen for browser changes to support direct Canva Hash URLs
        window.addEventListener('hashchange', router);
        window.addEventListener('load', () => {
            lucide.createIcons();
            router();
        });
    </script>
</body>
